{
  "name": "PieBrowser Android",
  "image": "mcr.microsoft.com/devcontainers/java:17",
  "features": {
    "ghcr.io/devcontainers/features/android-sdkmanager:1": {
      "sdkManagerPackages": "platforms;android-34 build-tools;34.0.0 platform-tools"
    }
  },
  "postCreateCommand": "chmod +x gradlew && ./gradlew dependencies --no-daemon || true",
  "customizations": {
    "vscode": {
      "extensions": ["vscjava.vscode-java-pack", "redhat.java"],
      "settings": {
        "java.configuration.updateBuildConfiguration": "automatic"
      }
    }
  },
  "remoteEnv": {
    "ANDROID_SDK_ROOT": "/usr/local/lib/android/sdk",
    "ANDROID_HOME": "/usr/local/lib/android/sdk"
  }
}
